<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <title>Login - Ms Kim Anh</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
            body {
                font-family: 'Poppins', sans-serif;
                background: #f5f7fb;
            }

            .login-container {
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .login-card {
                background: #fff;
                border-radius: 25px;
                box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                overflow: hidden;
                max-width: 900px;
                width: 100%;
            }

            .left-panel {
                background: linear-gradient(135deg, #6fb1fc, #4364f7);
                color: white;
                padding: 40px;
            }

                .left-panel h2 {
                    font-weight: 600;
                }

            .right-panel {
                padding: 40px;
            }

            .form-control {
                border-radius: 12px;
                padding: 10px;
            }

            .btn-login {
                background: linear-gradient(135deg, #ff9a44, #fc6076);
                border: none;
                border-radius: 12px;
                padding: 10px;
                color: white;
                font-weight: 600;
            }

                .btn-login:hover {
                    opacity: 0.9;
                }

            .logo {
                font-weight: 600;
                margin-bottom: 20px;
            }

    </style>
</head>
<body>

    <div class="login-container">
        <div class="login-card row g-0">

            <!-- Left -->
            <div class="col-md-6 left-panel d-flex flex-column justify-content-center">
                <h2>Ms Kim Anh</h2>
                <p>English Center</p>
                <p>Hệ thống học tiếng Anh hiện đại dành cho học sinh.</p>
            </div>

            <!-- Right -->
            <div class="col-md-6 right-panel">
                <h4 class="mb-4">Đăng nhập</h4>

                <form>
                    <div class="mb-3">
                        <label class="form-label">Tài khoản</label>
                        <input type="text" class="form-control" placeholder="Nhập tài khoản">
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" class="form-control" placeholder="Nhập mật khẩu">
                    </div>

                    <button type="submit" class="btn btn-login w-100">Đăng nhập</button>
                </form>
            </div>

        </div>
    </div>

</body>
</html>